import { SettingsPage } from "components/pages/settings.slint";
import { Palette } from "global.slint";
import { WindowToast } from "components/toast.slint";
import { PopupDialog } from "components/popup.slint";

component IconButton inherits Rectangle {
    in property <image> source;
    in property <length> icon-size: 18px;
    in property <bool> active: false;
    callback clicked();

    width: root.icon-size + 12px;
    height: root.icon-size + 12px;
    border-radius: 6px;
    
    background: root.active ? #ffffff16 : (ta.has-hover ? #ffffff0c : transparent);
    
    animate background { duration: 120ms; }

    Image {
        source: root.source;
        width: root.icon-size;
        height: root.icon-size;
        image-rendering: smooth;
        image-fit: contain;
        opacity: root.active ? 1.0 : (ta.has-hover ? 1.0 : 0.75);
        
        animate opacity { duration: 120ms; }
    }

    ta := TouchArea {clicked => { root.clicked() }}
}

export component MainWindow inherits Window {
    no-frame: true;
    background: transparent;
    resize-border-width: 6px;
    min-width: 960px;
    min-height: 540px;

    callback minimize-clicked();
    callback close-clicked();
    callback window-dragged(length, length);
    callback trigger-test-toast();

    in-out property <bool> show-settings: false;
    in-out property <bool> toast-active: false;
    in-out property <bool> dialog-active: false;
    in-out property <string> toast-text: "";
    in-out property <string> toast-kind: "success";
    in-out property <float> toast-progress: 1.0;

    Rectangle {
        width: 100%;
        height: 100%;

        Image {
            width: 100%;
            height: 100%;
            source: @image-url("../production/assets/background.jpg");
            image-fit: cover;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Rectangle {
            width: 100%;
            height: 100%;
            background: @linear-gradient(180deg, #00000044 0%, #00000088 100%);
        }

        VerticalLayout {
            alignment: start;
            padding: 0px;
            height: 100%;

            // Top Bar
            Rectangle {
                height: Palette.topbar-height;
                width: 100%;
                background: Palette.glass-background;
                border-width: 0px;
                drop-shadow-color: Palette.shadow-color;
                drop-shadow-blur: 15px;
                drop-shadow-offset-y: 4px;

                TouchArea {
                    width: 100%;
                    height: 100%;
                    moved => {
                        if (self.pressed) {
                            root.window-dragged(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                        }
                    }
                }

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;

                    HorizontalLayout {
                        alignment: start;
                        width: 30%;
                        VerticalLayout {
                            alignment: center;
                            IconButton {
                                source: @image-url("../production/assets/processed/settings.png");
                                icon-size: 22px;
                                active: root.show-settings;
                                clicked => { root.show-settings = !root.show-settings; }
                            }
                        }
                    }

                    HorizontalLayout {
                        alignment: center;
                        width: 40%;
                        VerticalLayout {
                            alignment: center;
                            Image {
                                source: @image-url("../production/assets/processed/logo.png");
                                width: 32px;
                                height: 32px;
                                image-rendering: smooth;
                                image-fit: contain;
                            }
                        }
                    }

                    HorizontalLayout {
                        alignment: end;
                        width: 30%;
                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                spacing: 8px;
                                IconButton {
                                    source: @image-url("../production/assets/processed/minimize.png");
                                    icon-size: 22px;
                                    clicked => { root.minimize-clicked(); }
                                }
                                IconButton {
                                    source: @image-url("../production/assets/processed/close.png");
                                    icon-size: 22px;
                                    clicked => { root.close-clicked(); }
                                }
                            }
                        }
                    }
                }
            }

            // Main Content Area (Expands to fill available space)
            Rectangle {
                vertical-stretch: 1.0;
                VerticalLayout {
                    padding: 30px;
                    spacing: 20px;
                    alignment: center;

                    HorizontalLayout {
                        spacing: 16px;
                        alignment: center;

                        Rectangle {
                            width: 150px;
                            height: 38px;
                            background: ta-toast.has-hover ? #ffffff14 : Palette.glass-background;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Palette.glass-border;
                            animate background { duration: 100ms; }

                            Text { text: "Test Toast"; color: #ffffff; font-size: 13px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                            ta-toast := TouchArea { 
                                clicked => { 
                                    root.trigger-test-toast();
                                } 
                            }
                        }

                        Rectangle {
                            width: 150px;
                            height: 38px;
                            background: ta-dialog.has-hover ? #ffffff14 : Palette.glass-background;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Palette.glass-border;
                            animate background { duration: 100ms; }

                            Text { text: "Test Popup"; color: #ffffff; font-size: 13px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                            ta-dialog := TouchArea { clicked => { root.dialog-active = true; } }
                        }
                    }
                }
            }

        }

        // Launch Button
        Rectangle {
            height: 60px;
            width: 240px;
            x: parent.width - self.width - 16px;
            y: parent.height - self.height - 14px;
            background: Palette.glass-background;
            border-radius: 12px;
            border-width: 1px;
            border-color: Palette.glass-border;
            drop-shadow-color: Palette.shadow-color;
            drop-shadow-blur: 15px;
            drop-shadow-offset-y: 4px;
            clip: true;

            HorizontalLayout {
                Rectangle {
                    horizontal-stretch: 1;
                    background: launch-ta.has-hover ? #ffffff12 : transparent;
                    animate background { duration: 120ms; }

                    launch-ta := TouchArea {} 

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 12px; 
                        spacing: 12px;
                        alignment: start;

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 20px;
                                height: 20px;
                                border-radius: 10px;
                                background: #ffffff;

                                Path {
                                    x: 4px;
                                    y: 5px;
                                    width: 12px;
                                    height: 10px;
                                    viewbox-x: 0;
                                    viewbox-y: 0;
                                    viewbox-width: 14;
                                    viewbox-height: 12;
                                    commands: "M1 6 L5 10 L13 1";
                                    stroke: #111111;
                                    stroke-width: 2px;
                                    fill: transparent;
                                }
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: "Launch";
                                color: #ffffff;
                                font-size: 15px;
                                font-weight: 700;
                            }
                        }
                    }
                }

                Rectangle {
                    width: 1px;
                    background: Palette.glass-border;
                }

                Rectangle {
                    width: 42px;
                    background: menu-ta.has-hover ? #ffffff12 : transparent;
                    animate background { duration: 120ms; }

                    menu-ta := TouchArea {}

                    VerticalLayout {
                        alignment: center;
                        HorizontalLayout {
                            alignment: center;
                            VerticalLayout {
                                alignment: center;
                                spacing: 4px;
                                for _ in [0, 1, 2]: Rectangle {
                                    width: 4px;
                                    height: 4px;
                                    border-radius: 2px;
                                    background: #ffffffcc;
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            width: 100%;
            height: 100%;
            border-width: 1px;
            border-color: Palette.glass-border;
        }

        if (root.show-settings) : SettingsPage {
            x: 20px;
            y: Palette.topbar-height + 15px;
            width: parent.width - 40px;
            height: parent.height - (Palette.topbar-height + 35px);
            close-settings => { root.show-settings = false; }
        }

        toast-widget := WindowToast {
            x: root.width - self.width - 24px;
            y: Palette.topbar-height + 16px;
            active: root.toast-active;
            kind: root.toast-kind;
            text: root.toast-text;
            timeout: 5000ms;
            close => { root.toast-active = false; }
        }

        dialog-widget := PopupDialog {
            active: root.dialog-active;
            background: root.dialog-active ? #000000aa : #00000000;
            title: "Apply Changes?";
            message: "Are you sure you want to write these modifications into your game files?";
            confirm => { root.dialog-active = false; }
            cancel => { root.dialog-active = false; }
        }
    }
}