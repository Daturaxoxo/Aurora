import { SettingsPage } from "components/pages/settings.slint";
import { Tr, TrKey } from "translations.slint";
export { Tr, TrKey } from "translations.slint";
import { Palette } from "global.slint";
import { WindowToast } from "components/toast.slint";
import { PopupDialog, CheckboxItem } from "components/popup.slint";
import { MenuPage } from "components/pages/menu.slint";
import { AddonsPage, AddonItem } from "components/pages/menus/addons.slint";
import { ModulesPage } from "components/pages/menus/modules.slint";
import { LuaScriptsPage } from "components/pages/menus/lua.slint";
import { ModManagerPage, ModItem } from "components/pages/modmanager.slint";
import {
    GameBananaBrowser,
    GbModItem,
    GbFileItem,
} from "components/gbbrowser.slint";
import {
    ScreenshotsPage,
    ScreenshotItem,
} from "components/pages/menus/screenshots.slint";

component IconButton inherits Rectangle {
    in property <image> source;
    in property <length> icon-size: 18px;
    in property <bool> active: false;
    callback clicked();

    width: root.icon-size + 12px;
    height: root.icon-size + 12px;
    border-radius: 6px;

    background: root.active ? #ffffff16 : (ta.has-hover ? #ffffff0c : transparent);

    animate background { duration: 120ms; }

    Image {
        source: root.source;
        width: root.icon-size;
        height: root.icon-size;
        image-rendering: smooth;
        image-fit: contain;
        opacity: root.active ? 1.0 : (ta.has-hover ? 1.0 : 0.75);

        animate opacity { duration: 120ms; }
    }

    ta := TouchArea {
        clicked => { root.clicked() }
    }
}

export component MainWindow inherits Window {
    title: "Aurora";
    no-frame: true;
    background: transparent;
    resize-border-width: 6px;
    min-width: 960px;
    min-height: 540px;

    // General Callbacks
    callback maximize-clicked();
    callback minimize-clicked();
    callback close-clicked();
    callback window-dragged(length, length);
    callback bottom-icon-clicked(int); // indexes: 0 = Menu, 1 = Mods Folder, 2 = Discord, 3 = GameBanana
    
    // [PROPERTIES]

    // Page Properties
    in-out property <bool> show-settings: false;
    in-out property <bool> show-menu: false;
    in-out property <bool> show-addons: false;
    in-out property <bool> show-modules: false;
    in-out property <bool> show-lua-scripts: false;
    in-out property <bool> show-mod-manager: false;
    in-out property <bool> show-screenshots: false;

    // Launch Button Properties
    in-out property <string> launch-button-text: "Launch";
    in-out property <bool> launch-disabled: false;
    callback launch-clicked();

    // Launch Menu Properties
    in-out property <bool> launch-menu-open: false;
    in-out property <bool> launch-menu-hover: false;
    callback launch-menu-action(int); // indexes: 0 = Repair, 1 = Check Updates, 2 = Desktop Shortcut, 3 = Open Mods Folder

    // Settings page callbacks
    callback setting-toggled(int);

    // Toast Properties
    in-out property <bool> toast-active: false;
    in-out property <string> toast-text: "";
    in-out property <string> toast-kind: "success";
    in-out property <float> toast-progress: 1.0;
    callback trigger-toast();

    // Settings Properties
    in-out property <int> language-index: 0;
    in-out property <bool> interface-minimization: false;
    in-out property <bool> discord-rpc: true;
    in-out property <string> game-directory: "";
    in-out property <int> engine-method-index: 0;
    in-out property <bool> developer-mode: false;
    in-out property <bool> extensive-logging: false;
    callback browse-game-directory();
    callback export-telemetry();
    callback language-index-changed(int);
    callback interface-minimization-changed(bool);
    callback discord-rpc-changed(bool);
    callback engine-method-index-changed(int);
    callback developer-mode-changed(bool);
    callback extensive-logging-changed(bool);

    // Popup Dialog Properties
    in-out property <bool> popup-active: false;
    in-out property <string> popup-id: "";
    in-out property <string> popup-title: "";
    in-out property <string> popup-message: "";
    in-out property <int> popup-confirm-delay: 0;
    in-out property <int> popup-required-count: 0;
    in-out property <[CheckboxItem]> popup-checkboxes: [];
    callback popup-confirm-callback(string);
    callback popup-cancel-callback(string);

    // Addons Page Properties
    in-out property <[AddonItem]> addons: [];
    callback addon-action(int);
    callback addon-open-link(int);

    // Mod Manager Properties
    in-out property <[ModItem]> mods: [];
    in-out property <[[ModItem]]> mods-grid: [];
    in-out property <bool> mods-view-grid: false;
    callback mods-view-changed(bool);
    in-out property <bool> mods-all-selected: false;
    in-out property <int> mods-selected-count: 0;
    callback mod-toggle(string);
    callback mod-delete(string);
    callback mod-rename(string, string);
    callback mod-select(string);
    callback mod-set-notes(string, string);
    callback mod-open-link(string);
    callback mod-move-to-group(string, string);
    callback mod-drop-on-zone(string, string);
    callback mod-drag-moved(string, length);
    callback mod-drag-dropped(string, length);
    in-out property <string> mods-drag-target: "";
    callback mods-select-all();
    callback mods-toggle-all();
    callback mods-toggle-selected();
    callback mods-delete-selected();
    callback mods-search-changed(string);
    callback mods-filter-changed(int);
    callback mods-refresh();
    callback open-mods-folder();
    callback mod-group-create();
    callback mod-group-rename(string, string);
    callback mod-group-delete(string);
    callback mod-group-toggle(string);
    callback mod-group-collapse(string);
    callback mod-group-select(string);
    callback mods-install-archive();
    callback mods-install-folder();
    in-out property <bool> mods-file-hover: false;

    // GameBanana Browser Properties
    in-out property <bool> show-gb-browser: false;
    in-out property <[GbModItem]> gb-mods: [];
    in-out property <bool> gb-loading: false;
    in-out property <bool> gb-show-nsfw: false;
    in-out property <int> gb-selected-character: -1;
    in-out property <string> gb-search-text: "";
    in-out property <[GbFileItem]> gb-files: [];
    in-out property <bool> gb-files-visible: false;
    in-out property <string> gb-files-mod-name: "";
    in-out property <bool> gb-preview-visible: false;
    in-out property <image> gb-preview-image;
    in-out property <bool> gb-preview-loading: false;
    in-out property <int> gb-preview-index: 0;
    in-out property <int> gb-preview-count: 0;
    in-out property <string> gb-preview-name: "";
    callback gb-preview-requested(int);
    callback gb-preview-nav(int);
    callback gb-opened();
    callback gb-search-changed(string);
    callback gb-character-selected(int);
    callback gb-nsfw-toggled(bool);
    callback gb-load-more();
    callback gb-install(int);
    callback gb-open-page(int);
    callback gb-file-chosen(int);

    // Modules Page Properties
    in-out property <[ModItem]> modules-list: [];
    in-out property <bool> modules-feature-enabled: false;
    in-out property <bool> modules-all-selected: false;
    in-out property <int> modules-selected-count: 0;
    callback module-choose();
    callback module-drop-files(string);
    callback module-rename(string, string);
    callback module-set-notes(string, string);
    callback module-delete(string, string);
    callback module-toggle(string);
    callback module-select(string);
    callback modules-select-all();
    callback modules-toggle-selected();
    callback modules-delete-selected();
    callback module-search-changed(string);
    callback modules-feature-toggled(bool);

    // Screenshots Page Properties
    in-out property <[ScreenshotItem]> screenshots: [];
    in-out property <int> screenshot-selected-count: 0;
    in-out property <image> screenshot-preview-image;
    callback screenshot-favorite(int);
    callback screenshot-delete(int);
    callback screenshot-open(int);
    callback screenshot-copy(int);
    callback screenshot-rename(int, string);
    callback screenshot-toggle-select(int);
    callback screenshot-delete-selected();
    callback screenshot-selection-cleared();
    callback screenshot-sort-changed(int);
    callback screenshot-favorites-filter-changed(bool);
    callback screenshot-preview-requested(int);
    callback screenshots-refresh();
    callback open-screenshots-folder();

    // [HELPER FUNCTIONS]

    // Popup Dialog Helpers
    function reset-popup() {
        root.popup-active = false;
        root.popup-id = "";
        root.popup-title = "";
        root.popup-message = "";
        root.popup-confirm-delay = 0;
        root.popup-required-count = 0;
        root.popup-checkboxes = [];
    }

    Rectangle {
        width: 100%;
        height: 100%;

        Image {
            width: 100%;
            height: 100%;
            source: @image-url("../production/assets/background.jpg");
            image-fit: cover;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Rectangle {
            width: 100%;
            height: 100%;
            background: @linear-gradient(180deg, #00000044 0%, #00000088 100%);
        }

        VerticalLayout {
            alignment: start;
            padding: 0px;
            height: 100%;

            // Top Bar
            Rectangle {
                height: Palette.topbar-height;
                width: 100%;
                background: Palette.glass-background;
                border-width: 0px;
                drop-shadow-color: Palette.shadow-color;
                drop-shadow-blur: 15px;
                drop-shadow-offset-y: 4px;

                TouchArea {
                    width: 100%;
                    height: 100%;
                    moved => {
                        if (self.pressed) {
                            root.window-dragged(self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                        }
                    }
                }

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;

                    HorizontalLayout {
                        alignment: start;
                        width: 30%;
                        VerticalLayout {
                            alignment: center;
                            IconButton {
                                source: @image-url("../production/icons/settings.png");
                                icon-size: 22px;
                                active: root.show-settings;
                                clicked => { root.show-settings = !root.show-settings; }
                            }
                        }
                    }

                    HorizontalLayout {
                        alignment: center;
                        width: 40%;
                        VerticalLayout {
                            alignment: center;
                            Image {
                                source: @image-url("../production/icons/logo.png");
                                width: 32px;
                                height: 32px;
                                image-rendering: smooth;
                                image-fit: contain;
                            }
                        }
                    }

                    HorizontalLayout {
                        alignment: end;
                        width: 30%;
                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                spacing: 8px;
                                IconButton {
                                    source: @image-url("../production/icons/minimize.png");
                                    icon-size: 22px;
                                    clicked => { root.minimize-clicked(); }
                                }

                                IconButton {
                                    source: @image-url("../production/icons/maximize.png");
                                    icon-size: 22px;
                                    clicked => {
                                        root.maximize-clicked();
                                        if root.maximized {
                                            self.source = @image-url("../production/icons/maximized.png")
                                        } else {
                                            self.source = @image-url("../production/icons/maximize.png");
                                        }
                                    }
                                }

                                IconButton {
                                    source: @image-url("../production/icons/close.png");
                                    icon-size: 22px;
                                    clicked => { root.close-clicked(); }
                                }
                            }
                        }
                    }
                }
            }
        }

        // Icon Row
        HorizontalLayout {
            x: 16px;
            y: parent.height - self.height - 14px;
            height: 60px;
            width: self.preferred-width;
            spacing: 8px;

            Rectangle {
                height: 60px;
                width: util-icon-row.preferred-width + 16px * 2;
                background: Palette.glass-background;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.glass-border;
                drop-shadow-color: Palette.shadow-color;
                drop-shadow-blur: 15px;
                drop-shadow-offset-y: 4px;

                util-icon-row := HorizontalLayout {
                    x: 16px;
                    y: 0px;
                    width: self.preferred-width;
                    height: parent.height;
                    spacing: 4px;
                    alignment: start;

                    VerticalLayout {
                        alignment: center;
                        IconButton {
                            source: @image-url("../production/icons/menu.png");
                            icon-size: 28px;
                            clicked => { root.bottom-icon-clicked(0); }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        IconButton {
                            source: @image-url("../production/icons/discord.png");
                            icon-size: 28px;
                            clicked => {
                                root.popup-id = "discord-popup";
                                root.popup-title = "Join Discord?";
                                root.popup-message = "Join our Discord server to keep in touch with future updates, sneakpeeks and ask questions!";
                                root.popup-required-count = 1;
                                root.popup-checkboxes = [{ label: "I agree that I am over 13 years old.", required: true, checked: false }];
                                root.popup-active = true;
                            }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        IconButton {
                            source: @image-url("../production/icons/gamebanana.png");
                            icon-size: 28px;
                            clicked => {
                                root.popup-id = "gamebanana-popup";
                                root.popup-title = "Open GameBanana?";
                                root.popup-message = "GameBanana is our mod hosting site partner where you can get mods to use on the game.";
                                root.popup-active = true;
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 60px;
                width: mod-manager-inner.preferred-width + 20px * 2;
                background: mod-manager-ta.has-hover ? #1b1b22dd : Palette.glass-background;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.glass-border;
                drop-shadow-color: Palette.shadow-color;
                drop-shadow-blur: 15px;
                drop-shadow-offset-y: 4px;
                animate background { duration: 120ms; }
                animate border-color { duration: 120ms; }

                mod-manager-ta := TouchArea {
                    clicked => { root.show-mod-manager = !root.show-mod-manager; }
                }

                mod-manager-inner := HorizontalLayout {
                    x: 20px;
                    y: 0px;
                    width: self.preferred-width;
                    height: parent.height;
                    spacing: 10px;
                    alignment: start;

                    VerticalLayout {
                        alignment: center;
                        Image {
                            source: @image-url("../production/icons/manager.png");
                            width: 26px;
                            height: 26px;
                            image-rendering: smooth;
                            image-fit: contain;
                            opacity: mod-manager-ta.has-hover ? 1.0 : 0.85;
                            animate opacity { duration: 120ms; }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "Mod Manager";
                            color: #ffffff;
                            font-family: "Segoe UI";
                            font-size: 14px;
                            font-weight: 600;
                        }
                    }
                }
            }
        }

        // Launch Button
        launch-button-root := Rectangle {
            height: 60px;
            width: 240px;
            x: parent.width - self.width - 16px;
            y: parent.height - self.height - 14px;
            background: Palette.glass-background;
            border-radius: 12px;
            border-width: 1px;
            border-color: Palette.glass-border;
            drop-shadow-color: Palette.shadow-color;
            drop-shadow-blur: 15px;
            drop-shadow-offset-y: 4px;
            clip: true;

            HorizontalLayout {
                Rectangle {
                    horizontal-stretch: 1;
                    background: launch-ta.has-hover ? #ffffff12 : transparent;
                    animate background { duration: 120ms; }

                    launch-ta := TouchArea {
                        enabled: !root.launch-disabled;
                        clicked => { root.launch-clicked(); }
                    }

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 12px;
                        spacing: 12px;
                        alignment: start;

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 20px;
                                height: 20px;
                                border-radius: 10px;
                                background: root.launch-disabled ? #ffffff55 : #ffffff;
                                animate background { duration: 200ms; }

                                Path {
                                    x: 4px;
                                    y: 5px;
                                    width: 12px;
                                    height: 10px;
                                    viewbox-x: 0;
                                    viewbox-y: 0;
                                    viewbox-width: 14;
                                    viewbox-height: 12;
                                    commands: "M1 6 L5 10 L13 1";
                                    stroke: #111111;
                                    stroke-width: 2px;
                                    fill: transparent;
                                }
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: root.launch-button-text;
                                color: root.launch-disabled ? #ffffff66 : #ffffff;
                                font-family: "Segoe UI";
                                font-size: 15px;
                                font-weight: 700;
                            }
                        }
                    }
                }

                Rectangle {
                    width: 1px;
                    background: Palette.glass-border;
                }

                menu-region := Rectangle {
                    width: 42px;
                    background: (menu-ta.has-hover || root.launch-menu-open) ? #ffffff1a : transparent;
                    animate background { duration: 120ms; }

                    menu-ta := TouchArea {
                        pointer-event(e) => {
                            if (e.kind == PointerEventKind.move) { root.launch-menu-open = true; }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        HorizontalLayout {
                            alignment: center;
                            VerticalLayout {
                                alignment: center;
                                spacing: 4px;
                                for _ in [0, 1, 2]: Rectangle {
                                    width: 4px;
                                    height: 4px;
                                    border-radius: 2px;
                                    background: (menu-ta.has-hover || root.launch-menu-open) ? #ffffffff : #ffffffcc;
                                    animate background { duration: 120ms; }
                                }
                            }
                        }
                    }
                }
            }
        }

        close-timer := Timer {
            interval: 250ms;
            running: root.launch-menu-open && !menu-ta.has-hover && !root.launch-menu-hover;
            triggered => {
                root.launch-menu-open = false;
                root.launch-menu-hover = false;
            }
        }

        if root.launch-menu-open: Rectangle {
            width: 100%;
            height: 100%;
            background: transparent;

            gap-filler := Rectangle {
                width: launch-card.width;
                x: launch-card.x;
                y: launch-card.y + launch-card.height;
                height: launch-button-root.y - self.y;
                background: transparent;

                gap-filler-ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    changed has-hover => {
                        root.launch-menu-hover = self.has-hover || launch-card.card-hover || menu-ta.has-hover;
                    }
                }
            }

            launch-card := Rectangle {
                width: 224px;
                x: parent.width - self.width - 16px;
                y: launch-button-root.y - self.height - 10px;
                background: Palette.glass-background;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.glass-border;
                drop-shadow-color: #00000099;
                drop-shadow-blur: 28px;
                drop-shadow-offset-y: 8px;
                height: menu-items-layout.preferred-height + 16px;

                property <bool> card-hover: card-padding-ta.has-hover || ri0.has-hover || ri1.has-hover || ri2.has-hover || ri4.has-hover;

                changed card-hover => { root.launch-menu-hover = self.card-hover || gap-filler-ta.has-hover || menu-ta.has-hover }

                card-padding-ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    changed has-hover => { root.launch-menu-hover = launch-card.card-hover || gap-filler-ta.has-hover || menu-ta.has-hover }
                }

                // Launch Menu Popup
                menu-items-layout := VerticalLayout {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    padding-top: 8px;
                    padding-bottom: -8px;
                    spacing: 1px;

                    Rectangle {
                        height: 40px;
                        width: parent.width;
                        border-radius: 6px;
                        background: ri0.has-hover ? #ffffff12 : transparent;
                        animate background { duration: 80ms; }
                        ri0 := TouchArea {
                            clicked => { root.launch-menu-action(0); root.launch-menu-open = false; }
                        }

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 12px;
                            alignment: start;
                            VerticalLayout {
                                alignment: center;
                                Image {
                                    source: @image-url("../production/icons/wrench.png");
                                    width: 16px;
                                    height: 16px;
                                    image-rendering: smooth;
                                    image-fit: contain;
                                    colorize: #ffffffaa;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "Repair Aurora";
                                    color: #ffffffdd;
                                    font-size: 13px;
                                    font-weight: 500;
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 40px;
                        width: parent.width;
                        border-radius: 6px;
                        background: ri1.has-hover ? #ffffff12 : transparent;
                        animate background { duration: 80ms; }
                        ri1 := TouchArea {
                            clicked => { root.launch-menu-action(1); root.launch-menu-open = false; }
                        }

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 12px;
                            alignment: start;
                            VerticalLayout {
                                alignment: center;
                                Image {
                                    source: @image-url("../production/icons/refresh.png");
                                    width: 16px;
                                    height: 16px;
                                    image-rendering: smooth;
                                    image-fit: contain;
                                    colorize: #ffffffaa;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "Check For Updates";
                                    color: #ffffffdd;
                                    font-size: 13px;
                                    font-weight: 500;
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 40px;
                        width: parent.width;
                        border-radius: 6px;
                        background: ri2.has-hover ? #ffffff12 : transparent;
                        animate background { duration: 80ms; }
                        ri2 := TouchArea {
                            clicked => { root.launch-menu-action(2); root.launch-menu-open = false; }
                        }

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 12px;
                            alignment: start;
                            VerticalLayout {
                                alignment: center;
                                Image {
                                    source: @image-url("../production/icons/monitor.png");
                                    width: 16px;
                                    height: 16px;
                                    image-rendering: smooth;
                                    image-fit: contain;
                                    colorize: #ffffffaa;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "Add Desktop Shortcut";
                                    color: #ffffffdd;
                                    font-size: 13px;
                                    font-weight: 500;
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 40px;
                        width: parent.width;
                        border-radius: 6px;
                        background: ri4.has-hover ? #ffffff12 : transparent;
                        animate background { duration: 80ms; }
                        ri4 := TouchArea {
                            clicked => { root.launch-menu-action(4); root.launch-menu-open = false; }
                        }

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 12px;
                            alignment: start;
                            VerticalLayout {
                                alignment: center;
                                Image {
                                    source: @image-url("../production/icons/folder.png");
                                    width: 16px;
                                    height: 16px;
                                    image-rendering: smooth;
                                    image-fit: contain;
                                    colorize: #ffffffaa;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "Open Mods Folder";
                                    color: #ffffffdd;
                                    font-size: 13px;
                                    font-weight: 500;
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            width: 100%;
            height: 100%;
            border-width: 1px;
            border-color: Palette.glass-border;
        }

        if (root.show-settings || root.show-menu || root.show-screenshots): Rectangle {
            width: 100%;
            height: parent.height - Palette.topbar-height;
            y: Palette.topbar-height + 1px;
            background: transparent;
            TouchArea {
                width: 100%;
                height: 100%;
            }
        }

        if (root.show-settings): SettingsPage {
            x: 20px;
            y: Palette.topbar-height + 15px;
            width: parent.width - 40px;
            height: parent.height - (Palette.topbar-height + 35px);
            close-settings => { root.show-settings = false; }

            language-index <=> root.language-index;
            interface-minimization <=> root.interface-minimization;
            discord-rpc <=> root.discord-rpc;
            game-directory <=> root.game-directory;
            engine-method-index <=> root.engine-method-index;
            developer-mode <=> root.developer-mode;
            extensive-logging <=> root.extensive-logging;

            browse-game-directory => { root.browse-game-directory(); }
            export-telemetry => { root.export-telemetry(); }
            language-index-changed(i) => { root.language-index-changed(i); }
            interface-minimization-changed(v) => { root.interface-minimization-changed(v); }
            discord-rpc-changed(v) => { root.discord-rpc-changed(v); }
            engine-method-index-changed(i) => { root.engine-method-index-changed(i); }
            developer-mode-changed(v) => { root.developer-mode-changed(v); }
            extensive-logging-changed(v) => { root.extensive-logging-changed(v); }
        }

        if root.show-menu: MenuPage {
            x: 0px;
            y: Palette.topbar-height;
            width: parent.width;
            height: parent.height - Palette.topbar-height;
            close-menu => { root.show-menu = false; }
            menu-item-clicked(i) => {
                root.show-menu = false;
                if (i == 0) { root.show-screenshots = true; }
                if (i == 2) { root.show-lua-scripts = true; }
                if (i == 3) { root.show-modules = true; }
                if (i == 4) { root.show-addons = true; }
            }
        }

        if root.show-lua-scripts: LuaScriptsPage {
            x: 0px;
            y: Palette.topbar-height;
            width: parent.width;
            height: parent.height - Palette.topbar-height;
            close-lua-scripts => { root.show-lua-scripts = false; }
        }

        if root.show-modules: ModulesPage {
            x: 0px;
            y: Palette.topbar-height;
            width: parent.width;
            height: parent.height - Palette.topbar-height;
            installed-modules <=> root.modules-list;
            feature-enabled <=> root.modules-feature-enabled;
            all-selected: root.modules-all-selected;
            selected-count: root.modules-selected-count;
            close-modules => { root.show-modules = false; }
            choose-module => { root.module-choose(); }
            drop-files(path) => { root.module-drop-files(path); }
            rename-module(id, name) => { root.module-rename(id, name); }
            save-module-notes(id, notes) => { root.module-set-notes(id, notes); }
            delete-module(id, name) => { root.module-delete(id, name); }
            toggle-module(id) => { root.module-toggle(id); }
            select-module(id) => { root.module-select(id); }
            select-all => { root.modules-select-all(); }
            toggle-selected => { root.modules-toggle-selected(); }
            delete-selected => { root.modules-delete-selected(); }
            search-changed(text) => { root.module-search-changed(text); }
            feature-toggled(enabled) => { root.modules-feature-toggled(enabled); }
        }

        if root.show-screenshots: ScreenshotsPage {
            x: 20px;
            y: Palette.topbar-height + 15px;
            width: parent.width - 40px;
            height: parent.height - (Palette.topbar-height + 35px);
            screenshots: root.screenshots;
            selected-count: root.screenshot-selected-count;
            preview-image: root.screenshot-preview-image;
            close-screenshots => { root.show-screenshots = false; }
            screenshot-favorite(i) => { root.screenshot-favorite(i); }
            screenshot-delete(i) => { root.screenshot-delete(i); }
            screenshot-open(i) => { root.screenshot-open(i); }
            screenshot-copy(i) => { root.screenshot-copy(i); }
            screenshot-rename(i, name) => { root.screenshot-rename(i, name); }
            screenshot-toggle-select(i) => { root.screenshot-toggle-select(i); }
            screenshot-delete-selected => { root.screenshot-delete-selected(); }
            screenshot-selection-cleared => { root.screenshot-selection-cleared(); }
            screenshot-sort-changed(i) => { root.screenshot-sort-changed(i); }
            screenshot-favorites-filter-changed(v) => { root.screenshot-favorites-filter-changed(v); }
            screenshot-preview-requested(i) => { root.screenshot-preview-requested(i); }
            screenshots-refresh => { root.screenshots-refresh(); }
            open-screenshots-folder => { root.open-screenshots-folder(); }
        }

        if root.show-addons: AddonsPage {
            x: 0px;
            y: Palette.topbar-height;
            width: parent.width;
            height: parent.height - Palette.topbar-height;
            addons <=> root.addons;
            close-addons => { root.show-addons = false; }
            addon-action(i) => { root.addon-action(i); }
            addon-open-link(i) => { root.addon-open-link(i); }
        }

        if root.show-mod-manager: ModManagerPage {
            x: 20px;
            y: Palette.topbar-height + 15px;
            width: parent.width - 40px;
            height: parent.height - (Palette.topbar-height + 35px);
            mods: root.mods;
            mods-grid: root.mods-grid;
            view-grid <=> root.mods-view-grid;
            view-changed(grid) => { root.mods-view-changed(grid); }
            all-selected: root.mods-all-selected;
            selected-count: root.mods-selected-count;
            file-hover: root.mods-file-hover;
            install-from-archive => { root.mods-install-archive(); }
            install-from-folder => { root.mods-install-folder(); }
            install-from-gamebanana => {
                root.show-gb-browser = true;
                root.gb-opened();
            }
            close-mod-manager => { root.show-mod-manager = false; }
            toggle-mod(id) => { root.mod-toggle(id); }
            delete-mod(id) => { root.mod-delete(id); }
            rename-mod(id, name) => { root.mod-rename(id, name); }
            select-mod(id) => { root.mod-select(id); }
            select-all => { root.mods-select-all(); }
            set-mod-notes(id, notes) => { root.mod-set-notes(id, notes); }
            open-mod-link(id) => { root.mod-open-link(id); }
            toggle-all => { root.mods-toggle-all(); }
            toggle-selected => { root.mods-toggle-selected(); }
            delete-selected => { root.mods-delete-selected(); }
            search-changed(text) => { root.mods-search-changed(text); }
            filter-changed(idx) => { root.mods-filter-changed(idx); }
            create-group => { root.mod-group-create(); }
            rename-group(id, name) => { root.mod-group-rename(id, name); }
            delete-group(id) => { root.mod-group-delete(id); }
            toggle-group(id) => { root.mod-group-toggle(id); }
            collapse-group(id) => { root.mod-group-collapse(id); }
            select-group(id) => { root.mod-group-select(id); }
            move-mod-to-group(id, group) => { root.mod-move-to-group(id, group); }
            drop-mod-on-zone(id, zone) => { root.mod-drop-on-zone(id, zone); }
            drag-target-group: root.mods-drag-target;
            mod-drag-moved(id, y) => { root.mod-drag-moved(id, y); }
            mod-drag-dropped(id, y) => { root.mod-drag-dropped(id, y); }
            refresh => { root.mods-refresh(); }
            open-mods-folder => { root.open-mods-folder(); }
            open-gamebanana => {
                root.popup-id = "gamebanana-popup";
                root.popup-title = "Open GameBanana?";
                root.popup-message = "GameBanana is our mod hosting site partner where you can get mods to use on the game.";
                root.popup-active = true;
            }
        }

        if root.show-gb-browser: GameBananaBrowser {
            x: 20px;
            y: Palette.topbar-height + 15px;
            width: parent.width - 40px;
            height: parent.height - (Palette.topbar-height + 35px);
            mods: root.gb-mods;
            loading: root.gb-loading;
            show-nsfw <=> root.gb-show-nsfw;
            selected-character <=> root.gb-selected-character;
            search-text <=> root.gb-search-text;
            files: root.gb-files;
            files-visible <=> root.gb-files-visible;
            files-mod-name: root.gb-files-mod-name;
            preview-visible <=> root.gb-preview-visible;
            preview-image: root.gb-preview-image;
            preview-loading: root.gb-preview-loading;
            preview-index: root.gb-preview-index;
            preview-count: root.gb-preview-count;
            preview-name: root.gb-preview-name;
            preview-requested(id) => { root.gb-preview-requested(id); }
            preview-nav(i) => { root.gb-preview-nav(i); }
            close => { root.show-gb-browser = false; }
            search-changed(text) => { root.gb-search-changed(text); }
            character-selected(i) => { root.gb-character-selected(i); }
            nsfw-toggled(v) => { root.gb-nsfw-toggled(v); }
            load-more => { root.gb-load-more(); }
            install(id) => { root.gb-install(id); }
            open-page(id) => { root.gb-open-page(id); }
            file-chosen(i) => { root.gb-file-chosen(i); }
        }

        toast-widget := WindowToast {
            x: root.width - self.width - 24px;
            y: Palette.topbar-height + 16px;
            active: root.toast-active;
            kind: root.toast-kind;
            text: root.toast-text;
            timeout: 5000ms;
            close => { root.toast-active = false; }
        }

        dialog-widget := PopupDialog {
            active: root.popup-active;
            background: root.popup-active ? #000000aa : #00000000;
            title: root.popup-title;
            message: root.popup-message;
            confirm-delay: root.popup-confirm-delay;
            required-count: root.popup-required-count;
            checkbox-items: root.popup-checkboxes;
            confirm => { root.popup-confirm-callback(root.popup-id); reset-popup() }
            cancel => { root.popup-cancel-callback(root.popup-id); reset-popup() }
        }
    }
}
