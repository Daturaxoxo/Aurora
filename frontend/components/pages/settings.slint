import { Palette } from "../../global.slint";
import { ScrollView } from "std-widgets.slint";
import { Languages } from "../../languages.slint";

// TOGGLE COMPONENT
component ToggleSwitch inherits Rectangle {
    in-out property <bool> checked;
    callback toggled();

    width: 44px;
    height: 24px;
    border-radius: 12px;
    background: root.checked ? #10b981 : #3f3f46;

    animate background { duration: 150ms; }

    Rectangle {
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: #ffffff;
        x: root.checked ? parent.width - self.width - 4px : 4px;

        animate x {
            duration: 150ms;
            easing: ease-out;
        }
    }

    TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }
    }
}

// DROPDOWN COMPONENT
export component Dropdown inherits Rectangle {
    in property <[string]> options: [];
    in-out property <int> selected-index: 0;
    in-out property <bool> opened: false;

    callback selection-changed(int);

    width: 140px;
    height: 32px;
    background: @linear-gradient(180deg, #15151aed 0%, #17171beb 100%);
    border-radius: 6px;
    border-width: 1px;
    border-color: Palette.glass-border;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        alignment: space-between;

        Text {
            text: root.options[root.selected-index];
            color: Palette.text-primary;
            font-size: 13px;
            font-family: "Segoe UI";
            vertical-alignment: center;
        }

        VerticalLayout {
            alignment: center;
            Image {
                source: @image-url("../../../production/icons/down.png");
                width: 16px;
                height: 16px;
                image-rendering: smooth;
                image-fit: contain;
                opacity: 0.7;
            }
        }
    }

    TouchArea {
        clicked => {
            root.opened = !root.opened;
            if (root.opened) { popup.show(); }
        }
    }

    popup := PopupWindow {
        x: 0px;
        y: parent.height + 4px;
        width: parent.width;

        Rectangle {
            background: #1e1e24;
            border-radius: 6px;
            border-width: 1px;
            border-color: #3f3f46;

            VerticalLayout {
                padding: 4px;
                spacing: 2px;
                for option[index] in root.options: Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: item-ta.has-hover ? #ffffff10 : transparent;

                    Text {
                        text: option;
                        x: 8px;
                        color: Palette.text-primary;
                        font-size: 13px;
                        font-family: "Segoe UI";
                        vertical-alignment: center;
                    }

                    item-ta := TouchArea {
                        clicked => {
                            root.selected-index = index;
                            root.opened = false;
                            root.selection-changed(index);
                        }
                    }
                }
            }
        }
    }
}

// TAB BUTTON COMPONENT
component TabButton inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();

    height: 38px;
    border-radius: 8px;
    background: root.active ? #ffffff0c : (ta.has-hover ? #ffffff04 : transparent);

    animate background { duration: 120ms; }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: root.text;
        x: 16px;
        color: root.active ? Palette.text-primary : (ta.has-hover ? Palette.text-primary : Palette.text-secondary);
        font-size: 14px;
        font-weight: root.active ? 600 : 400;
        font-family: "Segoe UI";
        vertical-alignment: center;

        animate color { duration: 120ms; }
    }
}

// SETTING CARD
component SettingCard inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;

    background: @linear-gradient(180deg, #15151aed 0%, #17171beb 100%);
    border-radius: 12px;
    border-width: 1px;
    border-color: Palette.glass-border;

    HorizontalLayout {
        padding: 16px;
        padding-right: 20px;
        alignment: space-between;

        VerticalLayout {
            spacing: 4px;
            alignment: center;

            Text {
                text: root.title;
                color: Palette.text-primary;
                font-size: 14px;
                font-weight: 600;
                font-family: "Segoe UI";
            }

            Text {
                text: root.subtitle;
                color: #cbd5e1;
                font-size: 12px;
                wrap: word-wrap;
                font-family: "Segoe UI";
            }
        }

        VerticalLayout {
            alignment: center;
            @children
        }
    }
}

component TabPage inherits Rectangle {
    in property <bool> active;

    width: 100%;
    height: 100%;
    visible: root.opacity > 0.01;

    states [
        active-state when root.active: {
            opacity: 1.0;
            y: 0px;
            in {
                animate opacity {
                    duration: 200ms;
                    easing: ease-in-out;
                    delay: 5ms;
                }
                animate y {
                    duration: 200ms;
                    easing: ease-in-out;
                    delay: 5ms;
                }
            }
        }
        inactive-state when !root.active: {
            opacity: 0.0;
            y: 6px;
            in {
                animate opacity {
                    duration: 100ms;
                    easing: ease-in-out;
                }
                animate y {
                    duration: 100ms;
                    easing: ease-in-out;
                }
            }
        }
    ]

    @children
}

// MAIN
export component SettingsPage inherits Rectangle {
    callback close-settings();
    in-out property <int> active-tab: 0;

    // --- GENERAL ---
    in-out property <int> language-index: 0;           // 0=English 1=Türkçe 2=简体中文 3=Español
    in-out property <bool> interface-minimization: false;
    in-out property <bool> discord-rpc: true;

    // --- LAUNCHER ---
    callback browse-game-directory();
    in-out property <string> game-directory: "C:\\Program Files\\Neverness To Everness";
    in-out property <int> engine-method-index: 0;      // 0=Default 1=Alternate

    // --- DEVELOPER ---
    in-out property <bool> developer-mode: false;
    in-out property <bool> extensive-logging: false;
    callback export-telemetry();

    // [CALLBACKS]
    callback interface-minimization-changed(bool);
    callback discord-rpc-changed(bool);
    callback engine-method-index-changed(int);
    callback developer-mode-changed(bool);
    callback extensive-logging-changed(bool);
    callback language-index-changed(int);

    background: @linear-gradient(180deg, #111115ef 0%, #16161aeb 100%);
    border-radius: 16px;
    border-width: 1px;
    border-color: Palette.glass-border;
    drop-shadow-color: Palette.shadow-color;
    drop-shadow-blur: 25px;
    drop-shadow-offset-y: 10px;

    HorizontalLayout {
        padding: 24px;
        spacing: 32px;

        // LEFT COLUMN: SIDEBAR NAVIGATION
        VerticalLayout {
            width: 180px;
            spacing: 8px;
            alignment: start;

            VerticalLayout {
                padding-left: 8px;
                padding-bottom: 12px;
                Text {
                    text: "SETTINGS";
                    color: Palette.text-secondary;
                    font-size: 11px;
                    font-weight: 700;
                    font-family: "Segoe UI";
                }
            }

            TabButton {
                text: "General";
                active: root.active-tab == 0;
                clicked => { root.active-tab = 0; }
            }

            TabButton {
                text: "Launcher";
                active: root.active-tab == 1;
                clicked => { root.active-tab = 1; }
            }

            TabButton {
                text: "Developer";
                active: root.active-tab == 2;
                clicked => { root.active-tab = 2; }
            }
        }

        // RIGHT COLUMN: PAGES VIEWS CONTENT
        VerticalLayout {
            spacing: 16px;

            HorizontalLayout {
                alignment: space-between;
                padding-bottom: 4px;

                Text {
                    text: root.active-tab == 0 ? "General" :
                        root.active-tab == 1 ? "Launcher" : "Developer";
                    color: Palette.text-primary;
                    font-size: 22px;
                    font-weight: 700;
                    font-family: "Segoe UI";
                }

                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: 6px;
                    background: ta.has-hover ? #ffffff10 : transparent;

                    animate background { duration: 100ms; }

                    Image {
                        source: @image-url("../../../production/icons/processed/close.png");
                        width: 14px;
                        height: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        opacity: ta.has-hover ? 1.0 : 0.7;
                        animate opacity { duration: 100ms; }
                    }

                    ta := TouchArea {
                        clicked => { root.close-settings(); }
                    }
                }
            }

            // LAYER STACKING BOX FOR INTERACTIVE CROSSFADE TRANSITIONS
            Rectangle {
                vertical-stretch: 1;

                // TAB 0: GENERAL SETTINGS CONTENT
                TabPage {
                    active: root.active-tab == 0;

                    ScrollView {
                        viewport-height: general-layout.min-height;
                        general-layout := VerticalLayout {
                            spacing: 24px;
                            alignment: start;

                            VerticalLayout {
                                spacing: 10px;
                                Text {
                                    text: "APPEARANCE";
                                    color: Palette.text-secondary;
                                    font-size: 11px;
                                    font-weight: 700;
                                    font-family: "Segoe UI";
                                }

                                SettingCard {
                                    title: "Language";
                                    subtitle: "Interface display language";
                                    Dropdown {
                                        options: Languages.names;
                                        selected-index <=> root.language-index;
                                        selection-changed(idx) => { root.language-index-changed(idx); }
                                    }
                                }

                                SettingCard {
                                    title: "Interface Minimization";
                                    subtitle: "Closes the launcher window after the game process initializes.";
                                    ToggleSwitch {
                                        checked <=> root.interface-minimization;
                                        toggled => { root.interface-minimization-changed(self.checked); }
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 10px;
                                Text {
                                    text: "INTEGRATION";
                                    color: Palette.text-secondary;
                                    font-size: 11px;
                                    font-weight: 700;
                                    font-family: "Segoe UI";
                                }

                                SettingCard {
                                    title: "Discord RPC";
                                    subtitle: "Toggle the in-built Rich Presence configuration status.";
                                    ToggleSwitch {
                                        checked <=> root.discord-rpc;
                                        toggled => { root.discord-rpc-changed(self.checked); }
                                    }
                                }
                            }
                        }
                    }
                }

                // TAB 1: LAUNCHER SETTINGS CONTENT
                TabPage {
                    active: root.active-tab == 1;

                    ScrollView {
                        viewport-height: launcher-layout.min-height;
                        launcher-layout := VerticalLayout {
                            spacing: 24px;
                            alignment: start;

                            VerticalLayout {
                                spacing: 10px;
                                Text {
                                    text: "GAME DIRECTORY";
                                    color: Palette.text-secondary;
                                    font-size: 11px;
                                    font-weight: 700;
                                    font-family: "Segoe UI";
                                }

                                SettingCard {
                                    title: "Game Directory";
                                    subtitle: ".";

                                    Rectangle {
                                        width: 76px;
                                        height: 32px;
                                        background: browse-ta.has-hover ? #ffffff14 : #ffffff08;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: #ffffff18;

                                        animate background { duration: 100ms; }

                                        Text {
                                            text: "Browse";
                                            color: Palette.text-primary;
                                            font-size: 13px;
                                            font-family: "Segoe UI";
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        browse-ta := TouchArea {
                                            clicked => { root.browse-game-directory(); }
                                        }
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 10px;
                                Text {
                                    text: "ENGINE";
                                    color: Palette.text-secondary;
                                    font-size: 11px;
                                    font-weight: 700;
                                    font-family: "Segoe UI";
                                }

                                SettingCard {
                                    title: "Engine Method";
                                    subtitle: "Choose what method the engine uses for loading mods.";
                                    Dropdown {
                                        options: ["Default", "Alternate"];
                                        selected-index <=> root.engine-method-index;
                                        selection-changed(idx) => { root.engine-method-index-changed(idx); }
                                    }
                                }
                            }
                        }
                    }
                }

                // TAB 2: DEVELOPER ENGINE BLOCK
                TabPage {
                    active: root.active-tab == 2;

                    ScrollView {
                        viewport-height: dev-layout.min-height;
                        dev-layout := VerticalLayout {
                            spacing: 24px;
                            alignment: start;

                            VerticalLayout {
                                spacing: 10px;
                                Text {
                                    text: "DEBUG";
                                    color: Palette.text-secondary;
                                    font-size: 11px;
                                    font-weight: 700;
                                    font-family: "Segoe UI";
                                }

                                SettingCard {
                                    title: "Developer Mode";
                                    subtitle: "Shows the log console for debugging.";
                                    ToggleSwitch {
                                        checked <=> root.developer-mode;
                                        toggled => { root.developer-mode-changed(self.checked); }
                                    }
                                }

                                SettingCard {
                                    title: "Extensive Logging";
                                    subtitle: "Allows for more logs to be shown in the console.";
                                    ToggleSwitch {
                                        checked <=> root.extensive-logging;
                                        toggled => { root.extensive-logging-changed(self.checked); }
                                    }
                                }

                                SettingCard {
                                    title: "Export Telemetry";
                                    subtitle: "Export your Aurora logs & system information to a file";

                                    Rectangle {
                                        width: 76px;
                                        height: 32px;
                                        background: export-ta.has-hover ? #ffffff14 : #ffffff08;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: #ffffff18;

                                        animate background { duration: 100ms; }

                                        Text {
                                            text: "Export";
                                            color: Palette.text-primary;
                                            font-size: 13px;
                                            font-family: "Segoe UI";
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        export-ta := TouchArea {
                                            clicked => { root.export-telemetry(); }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
