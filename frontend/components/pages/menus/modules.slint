import { Palette } from "../../../global.slint";
import { ScrollView } from "std-widgets.slint";
import { ToggleSwitch, ModItem, ModCard } from "../../modcard.slint";
import { PopupDialog } from "../../popup.slint";

export component ModulesPage inherits Rectangle {
    callback close-modules();
    callback choose-module();
    callback drop-files(string);

    callback rename-module(string, string); // <id>, <name> | <name>: The new name for the module
    callback save-module-notes(string, string); // <id>, <notes> | <notes>: The new note for the module
    callback delete-module(string, string); // <id>, <name> | <name>: The name of the module to be deleted
    callback toggle-module(string); // <id>
    callback select-module(string); // <id>
    callback select-all();
    callback toggle-selected();
    callback delete-selected();
    callback search-changed(string);
    callback feature-toggled(bool);

    in property <bool> all-selected: false;
    in property <int> selected-count: 0;

    in-out property <bool> feature-enabled: false;
    in-out property <string> search-text: "";

    in-out property <string> pending-delete-id: "";
    in-out property <string> pending-delete-name: "";
    in-out property <bool> pending-delete-selected: false;

    in-out property <[ModItem]> installed-modules: [];

    changed search-text => { root.search-changed(root.search-text); }

    background: #00000066;

    TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.close-modules(); }
    }

    panel := Rectangle {
        width: min(parent.width - 80px, 900px);
        height: parent.height - 60px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Palette.glass-background;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.glass-border;
        drop-shadow-color: Palette.shadow-color;
        drop-shadow-blur: 25px;
        drop-shadow-offset-y: 10px;

        TouchArea {
            width: 100%;
            height: 100%;
        }

        VerticalLayout {
            spacing: 0px;

            // Header
            header-root := Rectangle {
                height: 60px;
                width: 100%;

                HorizontalLayout {
                    x: 20px;
                    y: 0px;
                    width: parent.width - 40px;
                    height: parent.height;
                    spacing: 8px;

                    VerticalLayout {
                        alignment: center;
                        width: self.preferred-width;
                        Text {
                            text: "Third Party Modules";
                            color: Palette.text-primary;
                            font-family: "Segoe UI";
                            font-size: 17px;
                            font-weight: 700;
                        }
                    }

                    Rectangle {
                        width: 6px;
                    }

                    VerticalLayout {
                        alignment: center;
                        width: self.preferred-width;
                        add-modules-pill := Rectangle {
                            height: 28px;
                            width: add-modules-row.preferred-width + 24px;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: add-modules-ta.has-hover ? #ffffff28 : #ffffff16;
                            background: add-modules-ta.has-hover ? #ffffff12 : #ffffff08;
                            animate background { duration: 100ms; }
                            animate border-color { duration: 100ms; }

                            add-modules-ta := TouchArea {
                                clicked => { root.choose-module(); }
                            }

                            add-modules-row := HorizontalLayout {
                                x: 12px;
                                y: 0px;
                                height: parent.height;
                                width: self.preferred-width;
                                spacing: 7px;
                                alignment: center;

                                VerticalLayout {
                                    alignment: center;
                                    Path {
                                        width: 14px;
                                        height: 14px;
                                        viewbox-x: 0;
                                        viewbox-y: 0;
                                        viewbox-width: 14;
                                        viewbox-height: 14;
                                        commands: "M7 1 L7 13 M1 7 L13 7";
                                        stroke: #ffffffbb;
                                        stroke-width: 1.8px;
                                        fill: transparent;
                                    }
                                }

                                Text {
                                    text: "Add Modules";
                                    color: #ffffffcc;
                                    font-family: "Segoe UI";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        horizontal-stretch: 1;
                    }

                    VerticalLayout {
                        alignment: center;
                        width: self.preferred-width;
                        close-rect := Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 6px;
                            background: close-ta.has-hover ? #ffffff14 : transparent;
                            animate background { duration: 100ms; }

                            Path {
                                x: 7px;
                                y: 7px;
                                width: 14px;
                                height: 14px;
                                viewbox-x: 0;
                                viewbox-y: 0;
                                viewbox-width: 14;
                                viewbox-height: 14;
                                commands: "M1 1 L13 13 M13 1 L1 13";
                                stroke: close-ta.has-hover ? #ffffffdd : #ffffff66;
                                stroke-width: 1.8px;
                                fill: transparent;
                                animate stroke { duration: 100ms; }
                            }

                            close-ta := TouchArea {
                                clicked => { root.close-modules(); }
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: Palette.glass-border;
            }

            Rectangle {
                height: 48px;
                width: 100%;
                background: #ffffff02;

                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    spacing: 12px;

                    // Select all / deselect all
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 16px;
                            height: 16px;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: root.all-selected
                                ? #E8A020
                                : (select-all-ta.has-hover ? #ffffff77 : #ffffff44);
                            background: root.all-selected ? #E8A020 : transparent;
                            animate background { duration: 120ms; }
                            animate border-color { duration: 120ms; }

                            if root.all-selected: Path {
                                x: 2px;
                                y: 3px;
                                width: 12px;
                                height: 10px;
                                viewbox-x: 0;
                                viewbox-y: 0;
                                viewbox-width: 12;
                                viewbox-height: 10;
                                commands: "M1 5 L4 8 L11 1";
                                stroke: #111111;
                                stroke-width: 1.8px;
                                fill: transparent;
                            }

                            select-all-ta := TouchArea {
                                clicked => { root.select-all(); }
                            }
                        }
                    }

                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        search-container := Rectangle {
                            height: 32px;
                            background: #ffffff08;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: #ffffff16;

                            Image {
                                source: @image-url("../../../../production/icons/search.png");
                                x: 10px;
                                y: (parent.height - self.height) / 2;
                                width: 14px;
                                height: 14px;
                                image-rendering: smooth;
                                image-fit: contain;
                                colorize: #ffffff66;
                            }

                            TextInput {
                                x: 32px;
                                width: parent.width - 44px;
                                text <=> root.search-text;
                                font-family: "Segoe UI";
                                font-size: 13px;
                                color: Palette.text-primary;
                                vertical-alignment: center;
                            }

                            if (root.search-text == ""): Text {
                                x: 32px;
                                text: "Search modules...";
                                color: #ffffff44;
                                font-family: "Segoe UI";
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Bulk actions for the current selection
                    if root.selected-count > 0: VerticalLayout {
                        alignment: center;
                        toggle-sel-btn := Rectangle {
                            width: toggle-sel-text.preferred-width + 24px;
                            height: 28px;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: toggle-sel-ta.has-hover ? #ffffff28 : #ffffff16;
                            background: toggle-sel-ta.has-hover ? #ffffff12 : #ffffff08;
                            animate background { duration: 100ms; }

                            toggle-sel-text := Text {
                                text: "Toggle (" + root.selected-count + ")";
                                color: #ffffffcc;
                                font-family: "Segoe UI";
                                font-size: 12px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            toggle-sel-ta := TouchArea {
                                clicked => { root.toggle-selected(); }
                            }
                        }
                    }

                    if root.selected-count > 0: VerticalLayout {
                        alignment: center;
                        delete-sel-btn := Rectangle {
                            width: delete-sel-text.preferred-width + 24px;
                            height: 28px;
                            border-radius: 7px;
                            border-width: 1px;
                            border-color: #ee493766;
                            background: delete-sel-ta.has-hover ? #ee4937 : #ee4937cc;
                            animate background { duration: 100ms; }

                            delete-sel-text := Text {
                                text: "Delete (" + root.selected-count + ")";
                                color: Palette.text-primary;
                                font-family: "Segoe UI";
                                font-size: 12px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            delete-sel-ta := TouchArea {
                                clicked => { root.pending-delete-selected = true; }
                            }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 1px;
                            height: 20px;
                            background: Palette.glass-border;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "Enable Modules";
                            color: #ffffffcc;
                            font-family: "Segoe UI";
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        ToggleSwitch {
                            checked <=> root.feature-enabled;
                            toggled => { root.feature-toggled(root.feature-enabled); }
                        }
                    }
                }
            }

            // Modules List
            Rectangle {
                vertical-stretch: 1;
                background: transparent;

                ScrollView {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        padding-top: 12px;
                        padding-bottom: 12px;
                        spacing: 8px;
                        alignment: start;

                        for item[index] in root.installed-modules: ModCard {
                            show-icon: false;
                            item: item;
                            toggle-select(id) => { root.select-module(id); }
                            rename(id, name) => {
                                root.installed-modules[index].name = name;
                                root.rename-module(id, name);
                            }
                            set-notes(id, notes) => {
                                root.installed-modules[index].notes = notes;
                                root.save-module-notes(id, notes);
                            }
                            request-delete(id, name) => {
                                root.pending-delete-id = id;
                                root.pending-delete-name = name;
                            }
                            toggle-enabled(id) => {
                                root.installed-modules[index].enabled = !item.enabled;
                                root.toggle-module(id);
                            }
                        }

                        if root.installed-modules.length == 0: Text {
                            text: root.search-text == "" ? "No modules installed" : "No modules match your search";
                            color: #ffffff44;
                            font-family: "Segoe UI";
                            font-size: 13px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }
    }

    delete-dialog := PopupDialog {
        active: root.pending-delete-id != "" || root.pending-delete-selected;
        title: root.pending-delete-selected ? "Delete Selected Modules?" : "Delete Module?";
        message: root.pending-delete-selected
            ? "Are you sure you want to delete the " + root.selected-count + " selected module(s)?"
            : "Are you sure you want to delete \"" + root.pending-delete-name + "\"?";
        confirm => {
            if (root.pending-delete-selected) {
                root.delete-selected();
            } else if (root.pending-delete-id != "") {
                root.delete-module(root.pending-delete-id, root.pending-delete-name);
            }
            root.pending-delete-id = "";
            root.pending-delete-name = "";
            root.pending-delete-selected = false;
        }
        cancel => {
            root.pending-delete-id = "";
            root.pending-delete-name = "";
            root.pending-delete-selected = false;
        }
    }
}
