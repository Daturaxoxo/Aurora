import { Palette } from "../global.slint";

export struct CheckboxItem {
    label: string,
    required: bool,
    checked: bool,
}

export component PopupDialog inherits Rectangle {
    in property <bool> active;
    in property <string> title;
    in property <string> message;
    in property <int> confirm-delay: 0;
    in-out property <[CheckboxItem]> checkbox-items: [];
    in property <int> required-count: 0;

    callback confirm();
    callback cancel();

    private property <int> countdown: 0;
    private property <float> countdown-frac: 0.0;
    private property <bool> timer-ready: false;

    private property <int> required-checked-count:
        (checkbox-items.length > 0 && checkbox-items[0].required && checkbox-items[0].checked ? 1 : 0) +
        (checkbox-items.length > 1 && checkbox-items[1].required && checkbox-items[1].checked ? 1 : 0) +
        (checkbox-items.length > 2 && checkbox-items[2].required && checkbox-items[2].checked ? 1 : 0) +
        (checkbox-items.length > 3 && checkbox-items[3].required && checkbox-items[3].checked ? 1 : 0);

    private property <bool> all-required-checked:
        root.required-count == 0 || root.required-checked-count >= root.required-count;

    private property <bool> confirm-ready: root.timer-ready && root.all-required-checked;

    changed active => {
        if (root.active) {
            root.countdown = root.confirm-delay;
            root.countdown-frac = 0.0;
            root.timer-ready = root.confirm-delay <= 0;
            root.checkbox-items[0].checked = false;
            root.checkbox-items[1].checked = false;
            root.checkbox-items[2].checked = false;
            root.checkbox-items[3].checked = false;
        }
    }

    Timer {
        interval: 16ms;
        running: root.active && !root.timer-ready;
        triggered => {
            root.countdown-frac += 0.016;
            if (root.countdown-frac >= 1.0) {
                root.countdown-frac -= 1.0;
                root.countdown -= 1;
                if (root.countdown <= 0) {
                    root.countdown = 0;
                    root.timer-ready = true;
                }
            }
        }
    }

    width: 100%;
    height: 100%;

    background: root.active ? #00000066 : transparent;
    animate background { duration: 150ms; }

    visible: root.active || modal-box.opacity > 0.01;
    TouchArea { }

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;

            modal-box := Rectangle {
                width: 440px;
                background: Palette.glass-background;
                border-color: Palette.glass-border;
                border-width: 1px;
                border-radius: 12px;
                drop-shadow-color: Palette.shadow-color;
                drop-shadow-blur: 24px;
                drop-shadow-offset-y: 8px;

                opacity: root.active ? 1.0 : 0.0;
                animate opacity {
                    duration: 150ms;
                    easing: ease-in-out;
                }

                VerticalLayout {
                    padding: 24px;
                    spacing: 18px;

                    // Title
                    Text {
                        text: root.title;
                        font-size: 18px;
                        font-weight: 700;
                        color: Palette.text-primary;
                    }

                    // Message
                    Text {
                        text: root.message;
                        font-size: 13px;
                        color: Palette.text-secondary;
                        wrap: word-wrap;
                    }

                    // Checkbox
                    if root.checkbox-items.length > 0: VerticalLayout {
                        spacing: 10px;

                        for item[i] in root.checkbox-items: Rectangle {
                            height: 20px;

                            HorizontalLayout {
                                width: parent.width;
                                height: parent.height;
                                spacing: 10px;
                                alignment: start;

                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 16px;
                                        height: 16px;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: root.checkbox-items[i].checked
                                            ? (item.required ? #ffffff88 : #ffffff55)
                                            : (item.required ? #ffffff44 : #ffffff22);
                                        background: root.checkbox-items[i].checked ? #ffffff18 : transparent;
                                        animate background { duration: 120ms; }
                                        animate border-color { duration: 120ms; }

                                        if root.checkbox-items[i].checked: Path {
                                            x: 2px;
                                            y: 3px;
                                            width: 12px;
                                            height: 10px;
                                            viewbox-x: 0;
                                            viewbox-y: 0;
                                            viewbox-width: 12;
                                            viewbox-height: 10;
                                            commands: "M1 5 L4 8 L11 1";
                                            stroke: Palette.text-primary;
                                            stroke-width: 1.8px;
                                            fill: transparent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: item.label;
                                        font-size: 12px;
                                        color: item.required ? Palette.text-secondary : #ffffff55;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => {
                                    root.checkbox-items[i].checked = !root.checkbox-items[i].checked;
                                }
                            }
                        }
                    }

                    // Buttons
                    HorizontalLayout {
                        alignment: end;
                        spacing: 12px;

                        // Cancel
                        Rectangle {
                            width: 100px;
                            height: 34px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Palette.glass-border;
                            background: ta-cancel.has-hover ? #ffffff10 : transparent;
                            animate background { duration: 100ms; }

                            Text {
                                text: "Cancel";
                                color: Palette.text-secondary;
                                font-size: 13px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            ta-cancel := TouchArea {
                                clicked => { root.cancel(); }
                            }
                        }

                        // Confirm
                        Rectangle {
                            width: 100px;
                            height: 34px;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: root.confirm-ready ? Palette.glass-border : #ffffff18;
                            background: root.confirm-ready
                                ? (ta-confirm.has-hover ? #ffffff20 : #ffffff0c)
                                : #ffffff05;
                            animate background { duration: 100ms; }
                            animate border-color { duration: 200ms; }

                            Text {
                                text: root.timer-ready
                                    ? "Confirm"
                                    : "(" + root.countdown + ") Confirm";
                                color: root.confirm-ready ? Palette.text-primary : #ffffff33;
                                font-size: 13px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: 200ms; }
                            }

                            ta-confirm := TouchArea {
                                enabled: root.confirm-ready;
                                clicked => { root.confirm(); }
                            }
                        }
                    }
                }
            }
        }
    }
}
